# Hugging Face model and cache
HF_TOKEN=
HF_HOME=/opt/hf-cache
HF_HUB_ENABLE_HF_TRANSFER=1

# vLLM model server
MODEL_ID=Qwen/Qwen3.5-27B
SERVED_MODEL_NAME=qwen3.5-27b-amd
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
MAX_MODEL_LEN=32768
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
DTYPE=auto
ENABLE_QWEN_TOOL_CALLING=1

# Agent API and frontend server
AGENT_HOST=0.0.0.0
AGENT_PORT=8080
RUN_STORE_DIR=runs
CORS_ORIGINS=*

# Agent backend -> model endpoint
MODEL_BASE_URL=http://127.0.0.1:8000/v1
MODEL_NAME=qwen3.5-27b-amd
MODEL_API_KEY=EMPTY

# Optional health-check targets
AGENT_BASE_URL=http://127.0.0.1:8080
